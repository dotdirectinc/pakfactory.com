# Loaded by `sanity build` / `sanity deploy` (Vite production mode).
# Bundled into the DEPLOYED studio — re-run `pnpm sanity deploy` after changing.
# Public URLs, safe to commit. Names must match sanity.config.ts.

# Blog: deployed Vercel URL so the deployed studio previews against it.
SANITY_STUDIO_PREVIEW_URL_BLOG="https://pakfactory-blog.vercel.app"

# WWW: no deployed URL yet — falls back to http://localhost:3000 until one exists.
# SANITY_STUDIO_PREVIEW_URL_WWW="https://www.pakfactory.com"
