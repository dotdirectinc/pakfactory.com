# Optional overrides for `pnpm dev:blog` (port 3003).
# Sanity credentials are loaded from the repo root `.env.local` via next.config.ts (loadEnvConfig).
#
# If the dev banner shows "Project: (missing)", either:
# 1. Fill in root `.env.local` (see repo `.env.example`), or
# 2. Copy these three lines from root into `apps/blog/.env.local`:
#
# NEXT_PUBLIC_SANITY_PROJECT_ID=
# NEXT_PUBLIC_SANITY_DATASET=development
# SANITY_API_READ_TOKEN=

PORT=3003
# Origin only (no path). Blog path prefix lives in NEXT_PUBLIC_BLOG_BASE_PATH (PROD-1596).
NEXT_PUBLIC_SITE_URL=http://localhost:3003
# Empty today; set to "/blog" + basePath in next.config.ts for subpath hosting.
NEXT_PUBLIC_BLOG_BASE_PATH=

# Global indexing kill-switch. When truthy (1/true/yes/on), EVERY blog page is
# forced to noindex, nofollow — set it on preview/staging deploys (e.g. the
# *.vercel.app preview) so they never get indexed. Leave UNSET in production.
BLOG_DISABLE_INDEXING=

# Shared secret for the Sanity → /api/revalidate webhook (redirect/post changes).
# Send from Sanity as `Authorization: Bearer <secret>` or `?secret=<secret>`.
# Without it, /api/revalidate returns 503 and freshness relies on the 60s cache TTL.
SANITY_REVALIDATE_SECRET=

# Contributor pitch form (PROD-1504) — forwarded by /api/contribute
CONTRIBUTE_WEBHOOK_URL=
NEXT_PUBLIC_CONTRIBUTE_WEBHOOK_URL=
SANITY_STUDIO_PREVIEW_URL_BLOG=

# Algolia — nav typeahead + /search (Search-Only API key only)
NEXT_PUBLIC_ALGOLIA_APP_ID=<copy from root .env.local>
NEXT_PUBLIC_ALGOLIA_API_KEY=<copy from root .env.local>
