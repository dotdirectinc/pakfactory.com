# Repo root `.env.local` (ignored by git). `apps/www` and `apps/blog` load this via each app’s `next.config.ts`.
#
# --- Next.js apps (www + blog) — Sanity recommends NEXT_PUBLIC_* for project id + dataset ---
# @see https://www.sanity.io/docs/nextjs/configure-sanity-client-nextjs
NEXT_PUBLIC_SANITY_PROJECT_ID=""
NEXT_PUBLIC_SANITY_DATASET="production"
NEXT_PUBLIC_SANITY_API_VERSION="2025-09-25"
NEXT_PUBLIC_SANITY_STUDIO_URL="http://localhost:3333"
# Blog / JSON-LD — absolute origin including /blog basePath (canonical + OG)
NEXT_PUBLIC_SITE_URL="http://localhost:3001/blog"
# Blog newsletter webhook (PROD-1506 / S2.1) — optional until ESP is wired
NEWSLETTER_WEBHOOK_URL=""
# Blog RFQ CTA host — optional; defaults to https://www.pakfactory.com/contact
NEXT_PUBLIC_WWW_URL="http://localhost:3000"
# Viewer token — enables `drafts` perspective in local dev so unpublished docs still load on www/blog.
SANITY_API_READ_TOKEN=""

# Optional: same values as above if you prefer Studio-style names (apps fall back to these).
SANITY_STUDIO_PROJECT_ID=""
SANITY_STUDIO_DATASET="production"

# Editor token — required for npm run seed:demo (writes demo documents)
SANITY_API_WRITE_TOKEN=""
SANITY_STUDIO_PREVIEW_URL="http://localhost:3000"

# --- Sanity Studio (`apps/studio`) — CLI expects SANITY_STUDIO_* ---
# @see https://www.sanity.io/docs/studio/environment-variables

# shadcnstudio (premium registry auth — var names must be EMAIL/LICENSE_KEY per their CLI)
EMAIL=""
LICENSE_KEY=""
