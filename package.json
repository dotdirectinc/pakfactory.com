{
  "name": "pakfactory-sanity-poc",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:www": "turbo run dev --filter=@pakfactory/www",
    "dev:blog": "turbo run dev --filter=@pakfactory/blog",
    "dev:studio": "turbo run dev --filter=@pakfactory/studio",
    "build": "turbo run build",
    "build:www": "turbo run build --filter=@pakfactory/www",
    "build:blog": "turbo run build --filter=@pakfactory/blog",
    "build:studio": "turbo run build --filter=@pakfactory/studio",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "versions:apps": "npm pkg get name version versionCode --workspace=@pakfactory/www --workspace=@pakfactory/blog --workspace=@pakfactory/studio",
    "seed:demo": "npm run seed:demo --workspace=@pakfactory/sanity",
    "migrate:product-single-refs": "npm run migrate:product-single-refs --workspace=@pakfactory/sanity",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20.19"
  },
  "packageManager": "npm@10.9.2"
}
